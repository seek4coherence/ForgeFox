{
	"name": "@forgefox/cli",
	"version": "0.1.17",
	"description": "ForgeFox CLI - Run the ForgeFox agent from the command line",
	"private": true,
	"type": "module",
	"main": "dist/index.js",
	"bin": {
		"roo": "dist/index.js"
	},
	"scripts": {
		"format": "prettier --write 'src/**/*.ts'",
		"lint": "eslint src --ext .ts --max-warnings=0",
		"check-types": "tsc --noEmit",
		"test": "vitest run",
		"test:integration": "tsx scripts/integration/run.ts",
		"build": "tsup",
		"build:extension": "pnpm --filter forgefox bundle",
		"dev": "ROO_AUTH_BASE_URL=https://app.forgefox.com ROO_SDK_BASE_URL=https://cloud-api.forgefox.com FORGEFOX_PROVIDER_URL=https://api.forgefox.com/proxy tsx src/index.ts",
		"dev:local": "ROO_AUTH_BASE_URL=http://localhost:3000 ROO_SDK_BASE_URL=http://localhost:3001 FORGEFOX_PROVIDER_URL=http://localhost:8080/proxy tsx src/index.ts",
		"clean": "rimraf dist .turbo"
	},
	"dependencies": {
		"@inkjs/ui": "^2.0.0",
		"@forgefox/core": "workspace:^",
		"@forgefox/types": "workspace:^",
		"@forgefox/vscode-shim": "workspace:^",
		"@trpc/client": "^11.8.1",
		"@vscode/ripgrep": "^1.15.9",
		"commander": "^12.1.0",
		"cross-spawn": "^7.0.6",
		"execa": "^9.5.2",
		"fuzzysort": "^3.1.0",
		"ink": "^6.6.0",
		"p-wait-for": "^5.0.2",
		"react": "^19.1.0",
		"superjson": "^2.2.6",
		"zustand": "^5.0.0"
	},
	"devDependencies": {
		"@forgefox/config-eslint": "workspace:^",
		"@forgefox/config-typescript": "workspace:^",
		"@types/node": "^24.1.0",
		"@types/react": "^19.1.6",
		"ink-testing-library": "^4.0.0",
		"rimraf": "^6.0.1",
		"tsup": "^8.4.0",
		"vitest": "^3.2.3"
	}
}
